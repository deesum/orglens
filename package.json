{
  "name": "orglens",
  "version": "0.1.0",
  "description": "OrgLens — AI-powered Salesforce metadata health and tech-debt analyzer (Health Score, prioritized findings with rule docs, dependency impact, Jira-ready backlog).",
  "main": "dist/cli.js",
  "bin": {
    "orglens": "dist/cli.js"
  },
  "files": [
    "dist",
    "agent.config.example.yml",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,yml,yaml}\"",
    "prettier:verify": "npm run format:check",
    "prepublishOnly": "npm run build",
    "analyze:sample": "node dist/cli.js analyze --repo . --format json --mode local --out .orglens-sample-report.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deesum/config-reverse-engineer-agent.git"
  },
  "keywords": [
    "salesforce",
    "metadata",
    "technical-debt",
    "code-analysis",
    "pmd",
    "code-analyzer",
    "apex",
    "lwc",
    "health-score",
    "devops",
    "cli"
  ],
  "author": "Deepak Sumra",
  "license": "UNLICENSED",
  "type": "module",
  "bugs": {
    "url": "https://github.com/deesum/config-reverse-engineer-agent/issues"
  },
  "homepage": "https://github.com/deesum/config-reverse-engineer-agent#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "commander": "^15.0.0",
    "js-yaml": "^4.2.0",
    "openai": "^6.43.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
